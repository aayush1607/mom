# =============================================================================
# mom meal-agent backend — environment variables
# Copy to .env and fill in the values marked <REPLACE_ME>.
# =============================================================================

LOG_LEVEL=INFO

# --- Postgres ----------------------------------------------------------------
# Local install via `brew install postgresql@16` + `createdb meal_agent`.
# Default user is your OS user, no password.
POSTGRES_DSN=postgresql://aayush@localhost:5432/meal_agent
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=10

# --- Azure OpenAI ------------------------------------------------------------
# Endpoint format: https://<resource-name>.cognitiveservices.azure.com/
# Both deployments must live on this resource.
AZURE_OPENAI_ENDPOINT=https://auc16-mgtgm0lk-swedencentral.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<REPLACE_ME>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Cheap model used for parsing/routing/shortlist
AZURE_OPENAI_DEPLOYMENT_ROUTER=o4-mini
# Stronger model used for the dish pick
AZURE_OPENAI_DEPLOYMENT_PICKER=gpt-5.4

# --- Swiggy MCP --------------------------------------------------------------
# Production access is whitelist-only. Apply at https://mcp.swiggy.com/builders/access
# Once approved, complete the OAuth-PKCE flow via Claude Desktop / Cursor /
# VSCode and capture the bearer token, then paste below.
SWIGGY_MCP_FOOD_URL=https://mcp.swiggy.com/food
SWIGGY_MCP_DINEOUT_URL=https://mcp.swiggy.com/dineout
SWIGGY_MCP_TRANSPORT=streamable_http
# v1 uses food only; flip to true once dineout is allowlisted
SWIGGY_MCP_DINEOUT_ENABLED=false
# Name of env var holding the per-user OAuth token at request time.
SWIGGY_MCP_AUTH_TOKEN_ENV=SWIGGY_OAUTH_TOKEN
# The token itself (set when running the probe / single-tenant tests):
SWIGGY_OAUTH_TOKEN=<REPLACE_ME_AFTER_OAUTH>

# --- Agent tunables ----------------------------------------------------------
AGENT_MAX_SWAP_COUNT=1
AGENT_DISCOVER_TOP_N=15
AGENT_SHORTLIST_TOP_N=3
AGENT_INTERRUPT_TIMEOUT_MIN=60

# ── Real-money safety rails ───────────────────────────────────────────────────
# Default OFF. When false, place_order returns a synthetic DRYRUN_* order id
# and never calls Swiggy. Only set to true in the production deployment that
# you're prepared to actually charge users on.
AGENT_LIVE_ORDERS_ENABLED=false

# Default true. When true, Cash-on-Delivery is stripped from cart payment
# methods; mom requires the user to pre-pay in-app.
AGENT_BLOCK_COD=true
